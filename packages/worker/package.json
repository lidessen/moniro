{
  "name": "@moniro/agent-worker",
  "version": "0.1.0",
  "description": "Personal agent layer — identity, memory, prompt assembly, personal tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/lidessen/moniro.git",
    "directory": "packages/worker"
  },
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "typecheck": "tsgo",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@moniro/agent": "workspace:*",
    "bash-tool": "^1.3.12",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": ">=22",
    "@typescript/native-preview": "^7.0.0-dev.20260203.1",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "tsdown": "^0.20.1"
  }
}
