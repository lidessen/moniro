{
  "name": "@moniro/workspace",
  "version": "0.1.0",
  "description": "Workflow orchestration layer — multi-agent coordination, shared context, MCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/lidessen/moniro.git",
    "directory": "packages/workspace"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "typecheck": "tsgo",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@moniro/agent-loop": "workspace:*",
    "@moniro/agent-worker": "workspace:*",
    "ai": "^6.0.69",
    "bash-tool": "^1.3.12",
    "chalk": "^5.6.2",
    "grammy": "^1.41.1",
    "hono": "^4.11.9",
    "nanoid": "^5.1.6",
    "picocolors": "^1.1.1",
    "string-width": "^8.1.1",
    "wrap-ansi": "^9.0.2",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": ">=22",
    "@typescript/native-preview": "^7.0.0-dev.20260203.1",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "tsdown": "^0.20.1"
  }
}
